{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=OmniHubDb;Username=postgres;Password=YOUR_DATABASE_PASSWORD_HERE"
  },
  "JwtSettings": {
    "Secret": "YOUR_SUPER_SECRET_JWT_KEY_HERE",
    "Issuer": "OmniHubAPI",
    "Audience": "OmniHubClients",
    "DurationInMinutes": 60
  }
}