@page "/"
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject NavigationManager NavigationManager
@using OmniHub.Application.Features.Products.Queries;

<PageTitle>OmniHub Dashboard</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="fw-bold text-dark">OmniHub Inventory Management</h1>
    <button class="btn btn-outline-danger" @onclick="Logout">Secure Logout</button>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card border-0 shadow-sm p-4">
            <h4 class="fw-bold mb-3 text-dark">Add New Product</h4>
            
            @if (!string.IsNullOrEmpty(formMessage))
            {
                <div class="alert alert-info">@formMessage</div>
            }

            <div class="mb-3">
                <label class="form-label text-muted small fw-bold">SKU (Stock Code)</label>
                <input type="text" class="form-control" @bind="newProduct.SKU" placeholder="e.g.: KZN-WR-001" />
            </div>
            <div class="mb-3">
                <label class="form-label text-muted small fw-bold">Product Name</label>
                <input type="text" class="form-control" @bind="newProduct.Name" placeholder="e.g.: Red Sweater" />
            </div>
            <div class="mb-3">
                <label class="form-label text-muted small fw-bold">Stock Quantity</label>
                <input type="number" class="form-control" @bind="newProduct.TotalStock" />
            </div>
            <div class="mb-4">
                <label class="form-label text-muted small fw-bold">Price (₺)</label>
                <input type="number" class="form-control" @bind="newProduct.Price" />
            </div>
            <button class="btn btn-dark w-100 py-2 fw-bold" @onclick="AddProduct">
                Save Product
            </button>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card border-0 shadow-sm p-4">
            <h4 class="fw-bold mb-3 text-dark">Inventory Status</h4>
            @if (products == null)
            {
                <p><em>Loading data...</em></p>
            }
            else if (products.Count == 0)
            {
                <div class="text-center py-5">
                    <p class="text-muted mb-0">No products have been added yet. Use the form on the left to add your first product!</p>
                </div>
            }
            else
            {
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>SKU</th>
                            <th>Product Name</th>
                            <th>Stock</th>
                            <th>Price</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var product in products)
                        {
                            <tr>
                                <td class="fw-bold text-secondary">@product.SKU</td>
                                <td class="fw-semibold text-dark">@product.Name</td>
                                <td><span class="badge bg-success px-3 py-2">@product.TotalStock Units</span></td>
                                <td class="fw-bold text-dark">@product.Price.ToString("C")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

@code {
    private List<ProductDto>? products;
    private ProductFormModel newProduct = new();
    private string formMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");

        if (string.IsNullOrEmpty(token))
        {
            NavigationManager.NavigateTo("/login");
            return;
        }

        try
        {
            Http.DefaultRequestHeaders.Authorization = 
                new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            products = await Http.GetFromJsonAsync<List<ProductDto>>("api/Products");
        }
        catch
        {
            await Logout();
        }
    }

    private async Task AddProduct()
    {
        if (string.IsNullOrEmpty(newProduct.SKU) || string.IsNullOrEmpty(newProduct.Name))
        {
            formMessage = "Please fill in the SKU and Product Name fields.";
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("api/Products", newProduct);
            if (response.IsSuccessStatusCode)
            {
                formMessage = "Product added successfully!";
                newProduct = new ProductFormModel(); // Reset the form
                await LoadProducts(); // Refresh the list
            }
            else
            {
                formMessage = "An issue occurred while adding the product.";
            }
        }
        catch
        {
            formMessage = "API connection error.";
        }
    }

    private async Task Logout()
    {
        await LocalStorage.RemoveItemAsync("authToken");
        NavigationManager.NavigateTo("/login");
    }

    public class ProductFormModel
    {
        public string SKU { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public int TotalStock { get; set; } = 0;
        public decimal Price { get; set; } = 0;
    }
}